8:["$","$L14",null,{"wcProducts":[{"id":"cG9zdDo0Mw==","databaseId":43,"name":"White Dragon","slug":"white-dragon","description":"<p>Elegant White Dragon Katana featuring a white scabbard with golden dragon artwork, silver fittings, and traditional Japanese-inspired design. Perfect for collectors, anime fans, and cosplay displays.</p>\n","shortDescription":"<p>Forged in light, guided by honor.</p>\n<p>A blade for chosen guardians, protectors of balance, and warriors of destiny</p>\n","image":{"sourceUrl":"https://admin.nakamastore.ma/wp-content/uploads/2026/06/WHITE-DRAGON-scaled.png"},"galleryImages":{"nodes":[{"sourceUrl":"https://admin.nakamastore.ma/wp-content/uploads/2026/06/WHITE-DRAGON-3-2.png"},{"sourceUrl":"https://admin.nakamastore.ma/wp-content/uploads/2026/06/WHITE-DRAGON-2-2.png"},{"sourceUrl":"https://admin.nakamastore.ma/wp-content/uploads/2026/06/WHITE-DRAGON-4-2.png"},{"sourceUrl":"https://admin.nakamastore.ma/wp-content/uploads/2026/06/WHITE-DRAGON-1-2.png"}]},"productCategories":{"nodes":[{"name":"Uncategorized","slug":"uncategorized"}]},"price":"د.م.499.00","regularPrice":"د.م.499.00","salePrice":null},{"id":"cG9zdDozOA==","databaseId":38,"name":"Black Wall Mount","slug":"wall-mount","description":null,"shortDescription":"<p>Wall mount support for displaying your katana.</p>\n","image":{"sourceUrl":"https://admin.nakamastore.ma/wp-content/uploads/2026/06/ChatGPT-Image-15-juin-2026-11_08_23.png"},"galleryImages":{"nodes":[]},"productCategories":{"nodes":[{"name":"Accessories","slug":"accessories"}]},"price":"د.م.99.00","regularPrice":"د.م.99.00","salePrice":null},{"id":"cG9zdDoxMQ==","databaseId":11,"name":"Black Dragon","slug":"black-dragon","description":"<p>The Black Dragon decorative katana is designed as a display piece with a darker, mysterious aesthetic and premium decorative details. Made for collectors, anime lovers, gaming setups, and modern room decoration.</p>\n","shortDescription":"<p>Born from Darkness, feared in every realm.</p>\n<p>A weapon for dark Souls, shadow warriors, and broken heroes who walk alone on their path</p>\n","image":{"sourceUrl":"https://admin.nakamastore.ma/wp-content/uploads/2026/06/BLACK-DRAGON-scaled.png"},"galleryImages":{"nodes":[{"sourceUrl":"https://admin.nakamastore.ma/wp-content/uploads/2026/06/BLACK-DRAGON-4.png"},{"sourceUrl":"https://admin.nakamastore.ma/wp-content/uploads/2026/06/BLACK-DRAGON-3.png"},{"sourceUrl":"https://admin.nakamastore.ma/wp-content/uploads/2026/06/BLACK-DRAGON-1.png"},{"sourceUrl":"https://admin.nakamastore.ma/wp-content/uploads/2026/06/BLACK-DRAGON-2.png"}]},"productCategories":{"nodes":[{"name":"Uncategorized","slug":"uncategorized"}]},"price":"د.م.550.00","regularPrice":"د.م.550.00","salePrice":null},{"id":"cG9zdDozNw==","databaseId":37,"name":"Black Double Display Stand","slug":"double-display-stand","description":null,"shortDescription":"<p>Double display stand for two katanas.</p>\n","image":{"sourceUrl":"https://admin.nakamastore.ma/wp-content/uploads/2026/06/ChatGPT-Image-15-juin-2026-11_09_25.png"},"galleryImages":{"nodes":[]},"productCategories":{"nodes":[{"name":"Accessories","slug":"accessories"}]},"price":"د.م.150.00","regularPrice":"د.م.150.00","salePrice":null},{"id":"cG9zdDozNQ==","databaseId":35,"name":"Black Display Stand","slug":"display-stand","description":null,"shortDescription":"<p>Single display stand for one katana.</p>\n","image":{"sourceUrl":"https://admin.nakamastore.ma/wp-content/uploads/2026/06/ChatGPT-Image-Jun-15-2026-11_24_55-AM.png"},"galleryImages":{"nodes":[]},"productCategories":{"nodes":[{"name":"Accessories","slug":"accessories"}]},"price":"د.م.99.00","regularPrice":"د.م.99.00","salePrice":null}]}]
